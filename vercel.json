{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node@2" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/join/(.*)", "dest": "/public/controller.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
